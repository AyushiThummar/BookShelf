<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookShelf</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Default Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Project Auto Generated CSS -->
    <link rel="stylesheet" href="~/BookShelf.styles.css" asp-append-version="true" />

    <!-- 🔹 Your Custom Auth CSS -->
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />

    <!-- 🔹 Your Custom Register CSS -->
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />

    <!-- 🔹 Your Custom Forgot Password CSS -->
    <link rel="stylesheet" href="~/css/forgotpassword.css" asp-append-version="true" />

    <!-- 🔹 Your Custom Notification CSS -->
    <link rel="stylesheet" href="~/css/notification.css" asp-append-version="true" />

    <!-- 🔹 Your Custom User Profile CSS -->
    <link rel="stylesheet" href="~/css/userprofile.css" asp-append-version="true" />

    <!-- 🔹 Your Custom Edit User Profile CSS -->
    <link rel="stylesheet" href="~/css/EditUserProfile.css" asp-append-version="true" />

    <!-- 🔹 Your Custom About Us CSS -->
    <link rel="stylesheet" href="~/css/aboutus.css" asp-append-version="true" />

    <!-- 🔹 Your Custom Admin Profile CSS -->
    <link rel="stylesheet" href="~/css/AdminProfile.css" asp-append-version="true" />

     <!-- 🔹 Your Custom Admin Profile1 CSS -->
    <link rel="stylesheet" href="~/css/AdminProfile.css" asp-append-version="true" />

    <!-- 🔹 Your Custom Admin About Us CSS -->
    <link rel="stylesheet" href="~/css/admin-aboutus.css" asp-append-version="true" />

    <!-- 🔹 Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">BookShelf</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="m-0 p-0">
        @RenderBody()
    </main>

    @* <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - BookShelf - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> *@

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>