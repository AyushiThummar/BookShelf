<script>
    // Toggle wishlist heart fill/unfill
    function toggleWish(icon) {
        icon.classList.toggle('fa-regular');
        icon.classList.toggle('fa-solid');
        icon.style.color = icon.classList.contains('fa-solid') ? '#c0392b' : '#823838';
    }
</script>