@model BookShelf.Models.ViewModels.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - BookShelf</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Caveat:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/register.css" />
</head>
<body class="page-register">

    <canvas id="bg-canvas"></canvas>

    <div class="page-wrap">
        <div class="reg-card">

            <form asp-action="Register" method="post" enctype="multipart/form-data" id="regForm" class="reg-form">
                @Html.AntiForgeryToken()

                <input type="file" id="profileInput" name="ProfileImage" accept="image/*" style="display:none;" />

                <!-- LEFT PANEL -->
                <div class="panel-left">

                    <!-- HEADER: BookShelf left | Create Account centre -->
                    <div class="left-header">
                        <span class="brand">BookShelf</span>
                        <div class="welcome-block">
                            <h1 class="welcome-title">Create Account</h1>
                            <p class="welcome-sub">Join us — your bookshelf is waiting.</p>
                        </div>
                        <span class="header-spacer" aria-hidden="true">BookShelf</span>
                    </div>

                    <!-- TWO COLUMNS -->
                    <div class="fields-area">

                        <!-- SUB-LEFT: photo + name + gender -->
                        <div class="sub-left">

                            <div class="profile-section">
                                <div class="profile-ring-wrap">
                                    <div class="profile-ring" onclick="document.getElementById('profileInput').click();" title="Click to upload photo">
                                        <img src="~/images/reg_profile.png" id="profilePreview" class="profile-img" alt="Profile" />
                                        <div class="profile-overlay">
                                            <img src="~/images/reg_camera.png" class="camera-icon" alt="Upload" />
                                        </div>
                                    </div>
                                </div>
                                <span class="profile-hint">Click to upload photo</span>
                            </div>

                            <div class="field-group">
                                <label class="f-label">First Name</label>
                                @* Keep asp-for so model binding works; use autocomplete="nope" to block browser autofill *@
                                <input asp-for="FirstName" class="f-input"
                                       placeholder="Enter first name"
                                       autocomplete="nope"
                                       spellcheck="false" />
                                <span asp-validation-for="FirstName" class="f-error"></span>
                            </div>

                            <div class="field-group">
                                <label class="f-label">Last Name</label>
                                <input asp-for="LastName" class="f-input"
                                       placeholder="Enter last name"
                                       autocomplete="nope"
                                       spellcheck="false" />
                                <span asp-validation-for="LastName" class="f-error"></span>
                            </div>

                            <div class="field-group">
                                <label class="f-label">Gender</label>
                                <select asp-for="Gender" class="f-input f-select" autocomplete="nope">
                                    <option value="" disabled selected>Select gender</option>
                                    <option value="Female">Female</option>
                                    <option value="Male">Male</option>
                                    <option value="Other">Other</option>
                                    <option value="Prefer not to say">Prefer not to say</option>
                                </select>
                                <span asp-validation-for="Gender" class="f-error"></span>
                            </div>

                        </div>

                        <!-- SUB-RIGHT: email / mobile / passwords / address -->
                        <div class="sub-right">

                            <div class="field-group">
                                <label class="f-label">Email</label>
                                <input asp-for="Email" class="f-input"
                                       type="email"
                                       placeholder="yourname@gmail.com"
                                       autocomplete="nope" />
                                <span asp-validation-for="Email" class="f-error"></span>
                            </div>

                            <div class="field-group">
                                <label class="f-label">Mobile No</label>
                                <input asp-for="MobileNo" class="f-input"
                                       type="tel"
                                       inputmode="numeric"
                                       placeholder="10-digit mobile number"
                                       maxlength="10"
                                       autocomplete="nope"
                                       oninput="this.value=this.value.replace(/\D/g,'').slice(0,10)" />
                                <span asp-validation-for="MobileNo" class="f-error"></span>
                            </div>

                            <div class="field-group">
                                <label class="f-label">Password</label>
                                <div class="pw-wrap">
                                    <input asp-for="Password" id="pw1" class="f-input"
                                           type="password"
                                           placeholder="Create a password"
                                           autocomplete="new-password" />
                                    <button type="button" class="pw-toggle" onclick="togglePw('pw1','e1')" tabindex="-1">
                                        <svg id="e1" xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                        </svg>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="f-error"></span>
                            </div>

                            <div class="field-group">
                                <label class="f-label">Confirm Password</label>
                                <div class="pw-wrap">
                                    <input asp-for="ConfirmPassword" id="pw2" class="f-input"
                                           type="password"
                                           placeholder="Confirm your password"
                                           autocomplete="new-password" />
                                    <button type="button" class="pw-toggle" onclick="togglePw('pw2','e2')" tabindex="-1">
                                        <svg id="e2" xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                        </svg>
                                    </button>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="f-error"></span>
                            </div>

                            <div class="field-group">
                                <label class="f-label">Address</label>
                                <textarea asp-for="Address" class="f-input f-textarea"
                                          placeholder="Flat / House No., Street, City, Country"
                                          autocomplete="nope"></textarea>
                                <span asp-validation-for="Address" class="f-error"></span>
                            </div>

                        </div>

                    </div>

                    <!-- FOOTER -->
                    <div class="form-footer">
                        <button type="submit" class="btn-register" id="regBtn">
                            <span id="regBtnText">Create Account</span>
                            <span id="regBtnLoader" class="btn-loader" style="display:none">
                                <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                            </span>
                        </button>
                        <p class="signin-row">
                            Already have an account?
                            <a asp-controller="Account" asp-action="Login" class="signin-link">Sign In</a>
                        </p>
                    </div>

                </div>

                <!-- RIGHT PANEL -->
                <div class="panel-right">
                    <img src="~/images/login.png" class="right-img" alt="BookShelf illustration" />
                </div>

            </form>
        </div>
    </div>

    <script>
        /* block browser autofill on name fields by clearing on load then after short delay */
        window.addEventListener('load', function () {
            var fields = ['FirstName','LastName','Email','MobileNo'];
            fields.forEach(function(name) {
                var el = document.querySelector('[name="' + name + '"]');
                if (el) {
                    var val = el.value;
                    el.value = '';
                    setTimeout(function(){ if(!el.dataset.userTyped) el.value = ''; }, 300);
                    el.addEventListener('input', function(){ el.dataset.userTyped = '1'; });
                }
            });
        });

        /* profile image preview */
        document.getElementById('profileInput').addEventListener('change', function (e) {
            var f = e.target.files[0];
            if (f) {
                var r = new FileReader();
                r.onload = function (ev) { document.getElementById('profilePreview').src = ev.target.result; };
                r.readAsDataURL(f);
            }
        });

        /* password eye toggle */
        function togglePw(id, iconId) {
            var inp = document.getElementById(id);
            var ico = document.getElementById(iconId);
            var show = inp.type === 'password';
            inp.type = show ? 'text' : 'password';
            ico.innerHTML = show
                ? '<path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.477 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>'
                : '<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>';
        }

        /* loading dots on submit */
        document.getElementById('regForm').addEventListener('submit', function () {
            document.getElementById('regBtnText').style.display = 'none';
            document.getElementById('regBtnLoader').style.display = 'flex';
            document.getElementById('regBtn').disabled = true;
        });

        /* BACKGROUND CANVAS */
        (function () {
            var canvas = document.getElementById('bg-canvas');
            var ctx = canvas.getContext('2d');
            var W, H;
            function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; draw(); }
            function rRect(cx,cy,w,h,r,a) {
                ctx.save(); ctx.translate(cx,cy); ctx.rotate(a); ctx.beginPath();
                var hw=w/2,hh=h/2;
                ctx.moveTo(-hw+r,-hh); ctx.lineTo(hw-r,-hh); ctx.quadraticCurveTo(hw,-hh,hw,-hh+r);
                ctx.lineTo(hw,hh-r); ctx.quadraticCurveTo(hw,hh,hw-r,hh);
                ctx.lineTo(-hw+r,hh); ctx.quadraticCurveTo(-hw,hh,-hw,hh-r);
                ctx.lineTo(-hw,-hh+r); ctx.quadraticCurveTo(-hw,-hh,-hw+r,-hh);
                ctx.closePath(); ctx.restore();
            }
            function F(cx,cy,w,h,r,a,c){rRect(cx,cy,w,h,r,a);ctx.fillStyle=c;ctx.fill();ctx.strokeStyle='rgba(255,255,255,0.07)';ctx.lineWidth=1;ctx.stroke();}
            function O(cx,cy,w,h,r,a,c){rRect(cx,cy,w,h,r,a);ctx.strokeStyle=c;ctx.lineWidth=1.2;ctx.stroke();}
            function draw() {
                var g=ctx.createLinearGradient(0,0,W,H);
                g.addColorStop(0,'#7a2e2e'); g.addColorStop(1,'#4a1515');
                ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
                var s=Math.min(W,H);
                F(-s*.08,-s*.06,s*.52,s*.40,38,-0.38,'rgba(150,55,55,0.60)');
                F(-s*.02,s*.04,s*.44,s*.36,34,-0.28,'rgba(185,80,70,0.40)');
                O(-s*.04,s*.00,s*.48,s*.38,36,-0.32,'rgba(255,255,255,0.10)');
                F(W+s*.08,-s*.06,s*.52,s*.40,38,0.38,'rgba(140,48,48,0.58)');
                F(W+s*.02,s*.04,s*.44,s*.36,34,0.28,'rgba(175,75,65,0.38)');
                O(W+s*.04,s*.00,s*.48,s*.38,36,0.32,'rgba(255,255,255,0.09)');
                F(-s*.08,H+s*.06,s*.52,s*.40,38,0.38,'rgba(145,52,52,0.58)');
                F(-s*.02,H-s*.04,s*.44,s*.36,34,0.28,'rgba(180,78,68,0.38)');
                O(-s*.04,H-s*.01,s*.48,s*.38,36,0.32,'rgba(255,255,255,0.09)');
                F(W+s*.08,H+s*.06,s*.52,s*.40,38,-0.38,'rgba(155,58,58,0.60)');
                F(W+s*.02,H-s*.04,s*.44,s*.36,34,-0.28,'rgba(190,82,72,0.40)');
                O(W+s*.04,H-s*.01,s*.48,s*.38,36,-0.32,'rgba(255,255,255,0.10)');
                F(W*.50,-s*.12,s*.42,s*.32,32,0.05,'rgba(160,62,62,0.45)');
                O(W*.50,-s*.08,s*.46,s*.34,34,0.05,'rgba(255,255,255,0.08)');
                F(W*.50,H+s*.12,s*.42,s*.32,32,-0.05,'rgba(155,58,58,0.45)');
                O(W*.50,H+s*.08,s*.46,s*.34,34,-0.05,'rgba(255,255,255,0.08)');
                F(-s*.14,H*.50,s*.36,s*.44,36,0.55,'rgba(148,54,54,0.50)');
                O(-s*.10,H*.50,s*.38,s*.46,36,0.55,'rgba(255,255,255,0.08)');
                F(W+s*.14,H*.50,s*.36,s*.44,36,-0.55,'rgba(148,54,54,0.50)');
                O(W+s*.10,H*.50,s*.38,s*.46,36,-0.55,'rgba(255,255,255,0.08)');
            }
            window.addEventListener('resize', resize);
            resize();
        })();
    </script>

</body>
</html>
